PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# --- Email (for OTP verification) ---
# Easiest setup: Gmail with an "App Password" (not your normal password)
# 1. Enable 2-Step Verification on the Gmail account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Put that Gmail address + app password below
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com

# --- OR use generic SMTP instead of EMAIL_SERVICE ---
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# --- Twilio Verify (for phone number OTP verification) ---
# 1. Create/open a Verify Service in the Twilio Console:
#    https://console.twilio.com/us1/develop/verify/services
# 2. Copy your Account SID + Auth Token from the Twilio Console dashboard
# 3. Copy the Verify Service SID (starts with "VA...")
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
